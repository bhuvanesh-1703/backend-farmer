# Ignore node_modules for all sub-projects
node_modules/

# Ignore environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore build directories
dist/
build/

# Ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Ignore backend uploads so we don't commit user files
backend/uploads/

# Ignore editor-specific files
.idea/
.vscode/

# Ignore OS generated files
.DS_Store
Thumbs.db
